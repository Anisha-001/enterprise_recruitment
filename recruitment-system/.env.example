APP_NAME="Enterprise Recruitment"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://recruitment.enterprise.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=recruitment_system
DB_USERNAME=recruitment_user
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.recruitment.enterprise.com

BROADCAST_CONNECTION=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=recruitment_cache_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

MAIL_MAILER=sendmail
MAIL_SCHEME=null
MAIL_HOST=smtp.enterprise.com
MAIL_PORT=587
MAIL_USERNAME="recruitment@enterprise.com"
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="recruitment@enterprise.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Recruitment System Settings
RECRUITMENT_MAX_FILE_SIZE=10240
RECRUITMENT_ALLOWED_EXTENSIONS=pdf,doc,docx
RECRUITMENT_RESUME_STORAGE=resumes
RECRUITMENT_DOCUMENT_STORAGE=documents
RECRUITMENT_APPLICATION_PREFIX=APP

# Security
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_APPLICATIONS_PER_HOUR=5

# Features
FEATURE_AI_SCREENING=false
FEATURE_VIDEO_INTERVIEW=false
FEATURE_CALENDAR_SYNC=false

# External Integrations
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ENABLED=false

SLACK_WEBHOOK_URL=

# File Storage
FILESYSTEM_DISK_PRIVATE=s3
MEDIA_DISK=s3